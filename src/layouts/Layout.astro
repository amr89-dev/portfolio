---
interface Props {
	title: string;
}

const { title } = Astro.props;

import '@fontsource-variable/lexend-mega';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
   

		<title>{title}</title>
	</head>
	<body>
    <main class=" max-w-5xl mx-auto min-h-screen flex flex-col font-sans">

      <slot />
    </main>
	</body>
</html>

<style is:global>
  
  @import url('https://fonts.googleapis.com/css2?family=Lexend+Mega:wght@400;600;700&display=swap');

</style>